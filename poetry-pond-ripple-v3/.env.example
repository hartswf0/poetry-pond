# Copy this file to .env. The server loads .env automatically.
OPENAI_API_KEY=your-project-api-key

# Real GPT-5.6 model IDs.
OPENAI_SOL_MODEL=gpt-5.6-sol
OPENAI_LUNA_MODEL=gpt-5.6-luna

# efficient = local first, Luna routine, Sol only when needed
# deep      = prefer Sol for unsupported language and causal review
# luna      = Luna-only API path
OPENAI_AI_POLICY=efficient

# auto uses exact OpenAI input-token counting for Sol and near-budget calls.
# Valid values: auto, always, never
OPENAI_TOKEN_PREFLIGHT=auto

# Per-call context ceilings.
OPENAI_LUNA_PLANNER_INPUT_TOKENS=3200
OPENAI_SOL_PLANNER_INPUT_TOKENS=6200
OPENAI_SOL_REVIEW_INPUT_TOKENS=5200
OPENAI_LUNA_WRITER_INPUT_TOKENS=2800

# Per-turn safety gates.
OPENAI_MAX_CALLS_PER_TURN=3
OPENAI_MAX_SOL_CALLS_PER_TURN=1
OPENAI_MAX_COST_USD_PER_TURN=0.075

# Server controls.
HOST=127.0.0.1
PORT=8787
RATE_MAX=24
