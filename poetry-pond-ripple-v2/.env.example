# Optional. Without a key the complete deterministic local engine remains usable.
OPENAI_API_KEY=

# The planner proposes typed events only when the local grammar cannot safely interpret a line.
OPENAI_PLANNER_MODEL=gpt-5.6-sol

# The writer renders validated events into short poetic strata. It cannot alter world state.
OPENAI_WRITER_MODEL=gpt-5.6-sol

HOST=127.0.0.1
PORT=8787
RATE_WINDOW_MS=60000
RATE_MAX=24
